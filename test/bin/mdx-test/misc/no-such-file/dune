(rule
 (with-outputs-to
  test.output
  (with-accepted-exit-codes
   (not 0)
   (run %{bin:ocaml-mdx} test foo))))

(rule
 (alias runtest)
 (enabled_if (< %{version:cmdliner} "2.0.0"))
 (action
  (diff test.expected test.output)))

(rule
 (alias runtest)
 (enabled_if (>= %{version:cmdliner} "2.0.0"))
 (action
  (diff test.expected-cmdliner2 test.output)))
